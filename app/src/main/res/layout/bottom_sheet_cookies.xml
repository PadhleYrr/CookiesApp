<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111111"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#444444" />

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_cookie_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍪 Cookies"
                android:textColor="#00ff88"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_cookie_domain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#555555"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_close_sheet"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/btn_bg"
            android:src="@drawable/ic_close"
            android:contentDescription="Close"
            android:scaleType="center" />

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#222222" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_all"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="⎘ Copy All"
            android:textColor="#000000"
            android:backgroundTint="#00ff88"
            android:textSize="13sp"
            app:cornerRadius="10dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <View android:layout_width="8dp" android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_json"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="{ } JSON"
            android:textColor="#7b8cff"
            android:backgroundTint="#1a1a2e"
            android:textSize="13sp"
            app:cornerRadius="10dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:strokeColor="#7b8cff"
            app:strokeWidth="1dp" />

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#222222" />

    <!-- Cookie list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="350dp">

        <LinearLayout
            android:id="@+id/cookie_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />

    </ScrollView>

</LinearLayout>
